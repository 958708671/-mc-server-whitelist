# 数据库配置
DATABASE_URL=postgresql://username:password@localhost:5432/mc_whitelist

# 邮件配置
EMAIL_USER=your_email@qq.com
EMAIL_PASS=your_email_password

# QQ机器人配置
# 在 https://bot.q.qq.com/ 申请获取
QQ_BOT_APP_ID=your_app_id
QQ_BOT_TOKEN=your_bot_token
QQ_BOT_SECRET=your_app_secret
QQ_BOT_SANDBOX=true
QQ_BOT_ADMIN_QQ=958708671

# 服务器配置
SITE_URL=https://your-domain.vercel.app
ADMIN_EMAIL=admin@example.com

# RCON配置（用于自动添加白名单）
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=your_rcon_password
